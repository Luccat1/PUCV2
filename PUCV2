function evaluarPostulacionesPUCV2English() {
  const SHEET_ID = "1wxljJRiF6G9Ejs6e83BOTLTZFeiyZmSPCip_vpAdO4Q";
  const INPUT_SHEET = "Respuestas de formulario 1";
  const OUTPUT_SHEET = "Evaluación automatizada";

  const ss = SpreadsheetApp.openById(SHEET_ID);
  const hoja = ss.getSheetByName(INPUT_SHEET);
  if (!hoja) throw new Error("Hoja de entrada no encontrada: " + INPUT_SHEET);

  const lastRow = hoja.getLastRow();
  const lastCol = hoja.getLastColumn();
  if (lastRow < 2) return; // nada que procesar

  const datos = hoja.getRange(1, 1, lastRow, lastCol).getValues();
  const encabezados = datos[0].map(h => String(h || "").trim());
  const colIndex = {};
  encabezados.forEach((h, i) => colIndex[h] = i);

  const get = (fila, title) => {
    const i = colIndex[title];
    return i === undefined ? "" : String(fila[i] || "").trim();
  };
  const yes = v => /^s/i.test(String(v || "").trim()); // "Sí" que empieza con s
  const includesAny = (text, keys) => {
    const t = String(text || "").toLowerCase();
    return keys.reduce((acc, k) => acc + (t.includes(k) ? 1 : 0), 0);
  };

  const scoreTipoPostulante = txt => {
    const t = String(txt || "").toLowerCase();
    if (/acad[eé]mico|funcionario|investigador/.test(t)) return 2;
    if (/postgrado|posgrado/.test(t)) return 1.5;
    return 1;
  };

  const scoreUsoIngles = txt => {
    const claves = ["clases","investigaci","paper","traducci","documento","comunicaci","entrevista","presentaci","reuni","revisi","estudio","contrato","juríd","eventos","visitas","internacional","correo","instituci"];
    const matches = includesAny(txt, claves);
    return Math.min(4, matches * 0.25);
  };

  const scoreInternacionalizacion = txt => {
    const claves = ["programa identificado","postulación enviada","carta de aceptación","carta de invitación","contactos establecidos","correo","matricula","pasantía","pasantia"];
    const matches = claves.reduce((acc,k) => acc + (String(txt || "").toLowerCase().includes(k) ? 1 : 0), 0);
    return Math.min(5, matches);
  };

  const scoreCertificado = txt => {
    const t = String(txt || "");
    if (/C1/i.test(t)) return 5;
    if (/B2\.2/i.test(t)) return 4;
    if (/B2\.1/i.test(t)) return 3;
    if (/B1\+/i.test(t)) return 2;
    if (/inglés 4|ingles 4/i.test(t)) return 2;
    if (/exim/i.test(t)) return 3;
    return 1;
  };

  const resultados = [
    ["Nombre completo","Correo electrónico","Tipo de postulante","Nivel al que postula (con enlace a certificación)",
     "Disponibilidad (4)","Tipo postulante (2)","Uso del inglés (4)","Internacionalización (5)",
     "Nivel inglés (5)","Compromiso (3)","Carta (2)","Puntaje total"]
  ];

  for (let r = 1; r < datos.length; r++) {
    const fila = datos[r];
    // Combina nombres seguros
    const nombre = [ get(fila, "Primer nombre"), get(fila, "Apellido paterno"), get(fila, "Apellido materno") ].filter(Boolean).join(" ");
    const correo = get(fila, "Dirección de correo electrónico");
    const tipoPostulante = get(fila, "Indica si eres funcionario, alumno, profesor, investigador, etc.");
    const nivel = get(fila, "Nivel de curso al que postulas");
    const linkCert = get(fila, "Adjunta la certificación que permita verificar su nivel de inglés (certificado oficial, captura con aprobación y nota final de la asignatura u otros).");
    const nivelLink = linkCert ? `=HYPERLINK("${linkCert}", "${nivel || 'ver certificado'}")` : nivel;

    // 1. Disponibilidad (4 checks)
    let disp = 0;
    if (yes(get(fila, "¿Tienes disponibilidad para dedicar 3 sesiones semanales presenciales? (1 sesión = 70 minutos)"))) disp++;
    if (!/^s/i.test(get(fila, "¿Tienes compromisos académicos/laborales que podrían impedir cumplir con la asistencia obligatoria?"))) disp++; // "No" -> bueno
    if (yes(get(fila, "¿Estás en condiciones de asistir al menos al 85 % de las clases?"))) disp++;
    if (yes(get(fila, "¿Puedes comprometerse a dedicar 4 horas semanales de estudio autónomo además de las clases?"))) disp++;

    const tipo = scoreTipoPostulante(tipoPostulante);
    const uso = scoreUsoIngles(get(fila, "Describe brevemente las situaciones específicas en las que requieres usar inglés en tu trabajo:"));
    const intl = scoreInternacionalizacion(get(fila, "¿Tienes algún documento que respalde este proceso?"));
    const nivelIngles = scoreCertificado(get(fila, "Certificación de inglés"));

    // Compromiso (3)
    let compromiso = 0;
    if (yes(get(fila, "Compromiso con el programa "))) compromiso++;
    if (yes(get(fila, "Veracidad de la información"))) compromiso++;
    if (yes(get(fila, "Consecuencias por incumplimiento"))) compromiso++;

    // Carta (2)
    let carta = 0;
    if (yes(get(fila, "¿Cuentas con el respaldo de tu jefatura directa para participar en este programa?"))) carta++;
    if (get(fila, "Si la respuesta anterior fue \"Sí\", por favor, adjunta una carta de respaldo de tu jefatura?\" [Nota: Opcional, pero otorga puntaje adicional]")) carta++;

    const total = disp + tipo + uso + intl + nivelIngles + compromiso + carta;
    resultados.push([nombre, correo, tipoPostulante, nivelLink, disp, tipo, uso, intl, nivelIngles, compromiso, carta, total]);
  }

  let hojaResultados = ss.getSheetByName(OUTPUT_SHEET);
  if (!hojaResultados) hojaResultados = ss.insertSheet(OUTPUT_SHEET);
  else hojaResultados.clear();
  hojaResultados.getRange(1,1,resultados.length,resultados[0].length).setValues(resultados);
}